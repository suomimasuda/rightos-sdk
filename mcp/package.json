{
  "name": "@i-s3/rightos-mcp",
  "version": "0.4.3",
  "description": "MCP server for RightOS — queue/EV/pickup QR tickets for AI agents (Cursor, Claude). 18 tools, privacy-first, no end-user PII. npm: npx -y @i-s3/rightos-mcp",
  "mcpName": "io.github.suomimasuda/rightos-mcp",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "rightos",
    "qr",
    "digital-ticket",
    "queue-management",
    "queue",
    "clinic-waiting",
    "ev-charging",
    "privacy",
    "ai-agent",
    "cursor",
    "claude",
    "i-s3"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "author": "I-S3 Software Division",
  "homepage": "https://rightos.i-s3.com/software/rightos/docs/mcp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/suomimasuda/rightos-sdk.git",
    "directory": "mcp"
  },
  "type": "module",
  "bin": {
    "rightos-mcp": "dist/index.js"
  },
  "main": "./dist/index.js",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('fs').chmodSync('dist/index.js', 0o755)\"",
    "start": "node dist/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@i-s3/rightos": "^0.4.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
